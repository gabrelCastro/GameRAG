{
  "info": {
    "name": "GameRAG API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "game_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar usuário",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register/",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"joao\",\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha1234\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('access_token', res.access);",
                  "pm.collectionVariables.set('refresh_token', res.refresh);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login/",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin1234\"\n}"
            }
          }
        },
        {
          "name": "Renovar token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('access_token', res.access);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/token/refresh/",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Perguntar (RAG)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/chat/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Me recomenda um jogo de RPG de mundo aberto\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Games",
      "item": [
        {
          "name": "Listar jogos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/games/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Buscar jogos (search)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/games/?search=witcher",
              "host": ["{{base_url}}"],
              "path": ["api", "games", ""],
              "query": [{ "key": "search", "value": "witcher" }]
            },
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Ordenar jogos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/games/?ordering=-rating",
              "host": ["{{base_url}}"],
              "path": ["api", "games", ""],
              "query": [{ "key": "ordering", "value": "-rating" }]
            },
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Detalhar jogo",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/games/{{game_id}}/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Cadastrar jogo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('game_id', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/games/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Witcher 3\",\n  \"description\": \"RPG de mundo aberto épico ambientado num universo de fantasia sombria.\",\n  \"genre\": \"RPG\",\n  \"platform\": \"PC\",\n  \"price\": \"99.90\",\n  \"developer\": \"CD Projekt Red\",\n  \"publisher\": \"CD Projekt\",\n  \"release_date\": \"2015-05-19\",\n  \"tags\": [\"RPG\", \"Open World\", \"Fantasy\"],\n  \"rating\": \"9.8\"\n}"
            }
          }
        },
        {
          "name": "Atualizar jogo (PUT)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/games/{{game_id}}/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"The Witcher 3\",\n  \"description\": \"RPG de mundo aberto épico ambientado num universo de fantasia sombria.\",\n  \"genre\": \"RPG\",\n  \"platform\": \"PC\",\n  \"price\": \"79.90\",\n  \"developer\": \"CD Projekt Red\",\n  \"publisher\": \"CD Projekt\",\n  \"release_date\": \"2015-05-19\",\n  \"tags\": [\"RPG\", \"Open World\", \"Fantasy\"],\n  \"rating\": \"9.8\"\n}"
            }
          }
        },
        {
          "name": "Atualizar jogo (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/games/{{game_id}}/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": \"79.90\"\n}"
            }
          }
        },
        {
          "name": "Remover jogo",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/games/{{game_id}}/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Jogos similares",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/games/{{game_id}}/similar/?limit=5",
              "host": ["{{base_url}}"],
              "path": ["api", "games", "{{game_id}}", "similar", ""],
              "query": [{ "key": "limit", "value": "5" }]
            },
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Listar avaliações do jogo",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/games/{{game_id}}/reviews/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Criar ou atualizar minha avaliação",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/games/{{game_id}}/reviews/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 9,\n  \"comment\": \"Excelente RPG, com boa progressão e mundo aberto.\"\n}"
            }
          }
        },
        {
          "name": "Remover minha avaliação",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/games/{{game_id}}/reviews/me/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Favoritar jogo",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/games/{{game_id}}/favorite/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Remover favorito",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/games/{{game_id}}/favorite/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Listar meus favoritos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/games/favorites/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Adicionar jogo à minha biblioteca",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/games/{{game_id}}/library/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"playing\",\n  \"hours_played\": \"12.5\"\n}"
            }
          }
        },
        {
          "name": "Atualizar jogo na minha biblioteca",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/games/{{game_id}}/library/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\",\n  \"hours_played\": \"45.0\"\n}"
            }
          }
        },
        {
          "name": "Remover jogo da minha biblioteca",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/games/{{game_id}}/library/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        },
        {
          "name": "Listar minha biblioteca",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/games/library/",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{access_token}}" }]
            }
          }
        }
      ]
    }
  ]
}
